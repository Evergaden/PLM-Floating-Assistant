{
  "name": "plm-cloud-backup",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "db:create": "wrangler d1 create plm-cloud-backup-db",
    "db:migrate:remote": "wrangler d1 execute plm-cloud-backup-db --remote --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute plm-cloud-backup-db --local --file=./schema.sql"
  },
  "devDependencies": {
    "wrangler": "^4.20.5"
  }
}
